# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO — JOCA/CCENT
# ============================================================
# 1. Copiar este archivo como .env:   cp .env.example .env
# 2. Definir valores reales en .env
# 3. NUNCA commitear .env con datos reales
# ============================================================

# --- Base de datos PostgreSQL (Docker Compose) ---
POSTGRES_USER=joca_user
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA
POSTGRES_DB=joca_db

# --- Variables Django (base de datos) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=joca_db
DB_USER=joca_user
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA
DB_HOST=db
DB_PORT=5432

# Alternativa: URL completa (opcional)
# DATABASE_URL=postgresql://joca_user:CAMBIA_ESTA_CONTRASENA@db:5432/joca_db

# ============================================================
# SEGURIDAD DJANGO
# ============================================================
# Clave secreta: minimo 50 caracteres aleatorios, unica por entorno.
# Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CAMBIA-ESTA-CLAVE-POR-UNA-ALEATORIA-Y-LARGA-MINIMO-50-CHARS

# False en dev/local, True solo si HTTPS esta configurado en produccion.
DJANGO_SECURE=False

# Nunca True en produccion.
DJANGO_DEBUG=False

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# EMAIL
# ============================================================
# DESARROLLO - los emails se imprimen en consola (sin SMTP):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# PRODUCCION - SMTP real:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=correo@example.com
EMAIL_HOST_PASSWORD=CONTRASENA_DE_APP_O_TOKEN
DEFAULT_FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=contacto@example.com

# ============================================================
# RECAPTCHA (configurar en console.cloud.google.com)
# ============================================================
RECAPTCHA_ENABLED=True
RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
# Para desarrollo local: usar keys de prueba de Google
# RECAPTCHA_USE_TEST_KEYS=True

# ============================================================
# PORTAL PUBLICO - INFORMACION DE CONTACTO DE LA INSTITUCION
# ============================================================
PORTAL_CONTACT_PHONE=0000000
PORTAL_CONTACT_WHATSAPP=0000000000
PORTAL_CONTACT_EMAIL=contacto@example.com
PORTAL_CONTACT_SCHEDULE=Lunes a Viernes de 09:00 a 18:00
PORTAL_CONTACT_ADDRESS=Direccion de la institucion, Ciudad, CP

# ============================================================
# SENTRY (opcional - monitoreo de errores en produccion)
# Instalar: pip install "sentry-sdk[django]>=2.0,<3.0"
# Dejar vacio para desactivar.
# ============================================================
SENTRY_DSN=
